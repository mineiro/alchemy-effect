---
import { yantraSvg } from "./yantra";

interface Props {
  size?: number;
  stroke?: string;
  dot?: string;
  bg?: string;
  strokeWidth?: number;
  /** Inherit color from surrounding text (default true for inline use). */
  useCurrentColor?: boolean;
  class?: string;
}

const {
  size = 42,
  stroke,
  dot,
  bg,
  strokeWidth,
  useCurrentColor = true,
  class: className,
} = Astro.props;

const svg = yantraSvg({ size, stroke, dot, bg, strokeWidth, useCurrentColor });
---

<span class={className} aria-hidden="true" set:html={svg} />
